<?xml version="1.0" encoding="UTF-8"?>


<web-app> 

	<display-name>BrickCaveau</display-name>
	
	<welcome-file-list>
		<welcome-file>index.jsp</welcome-file>
	</welcome-file-list>
	
	<resource-ref>
		<description>Database BrickCaveau</description>
		<res-ref-name>jdbc/BrickCaveau</res-ref-name>
		<res-type>javax.sql.DataSource</res-type>
		<res-auth>Container</res-auth>
	</resource-ref>
	
	<error-page>
		<error-code>404</error-code>
		<location>/errori/404.jsp</location>
	</error-page>
	
	<error-page>
		<error-code>500</error-code>
		<location>/errori/500.jsp</location>
	</error-page>
	
	<error-page>
		<error-code>403</error-code>
		<location>/errori/403.jsp</location>
	</error-page>
	
</web-app>